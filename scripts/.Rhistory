#   A   Archeophyt (< 1500)      -> CH_ARCHEOPHYTE
#   AC  Cultivated archeophyte   -> CH_ARCHEOPHYTE
#   N   Neophyt (> 1500)         -> CH_NON_NATIVE_SPECIES
#   NC  Cultivated neophyte      -> CH_NON_NATIVE_SPECIES
